{
  "server": {
    "port": 5500,
    "sample_rate": 8000,
    "packet_ms": 20,
    "opus": {
      "bitrate": 16000,
      "complexity": 5,
      "fec": true,
      "dtx": false,
      "application": "voip"
    },
    "hangover_ms": 180,
    "eof_timeout_ms": 420,
    "conceal_decay": 0.90,
    "jitter_min_packets": 2,
    "jitter_adapt_enabled": true,
    "jitter_max_packets": 10,
    "busy_mode": false,
    "transmit_timeout": 60
  },
  "modules": {
    "generators": {
      "squelch_shots": {
        "enabled": true,
        "interval_min_ms": 80000,
        "interval_max_ms": 900000,
        "silence_min_ms": 5,
        "silence_max_ms": 200,
        "signal_min_percent": 4.0,
        "signal_max_percent": 10.0
      }
    },
    "dsp": {
      "chain": ["compressor", "pops", "clicks", "filter", "noise", "squelch", "distortion", "dispersion"],
      "clicks": {
        "enabled": true,
        "multi_client_rapid_ms": 0,
        "impulse_prob_at_weak_signal": 0.98,
        "impulse_prob_at_strong_signal": 0.05,
        "impulse_gain_db": 5.0,
        "impulse_gain_at_weak_signal_db": 0.0,
        "impulse_gain_at_strong_signal_db": -20.0,
        "filter": {
          "enabled": true,
          "low_cut_hz": 300.0,
          "high_cut_hz": 3500.0
        }
      },
      "pops": {
        "enabled": true,
        "click_db": 0.0,
        "click_tone_hz": 100.0,
        "glitch_interval_max_ms": 2000,
        "glitch_freq_min_hz": 120.0,
        "glitch_freq_max_hz": 200.0,
        "glitch_level_min_db": -25.0,
        "glitch_level_max_db": -11.0
      },
      "noise": {
        "enabled": true,
        "signal_dependent": true,
        "min_noise_db": -27.0,
        "max_noise_db": 3.0,
        "noise_gain": 1200.0,
        "noise_distribution": "uniform",
        "thermal_lowpass_hz": 8000
      },
      "squelch": {
        "enabled": true,
        "threshold_percent": 5.0,
        "squelch_min_ms": 10,
        "squelch_max_ms": 20,
        "noise_distribution": "gaussian",
        "thermal_lowpass_hz": 6000,
        "noise_gain": 1200.0,
        "tail_noise_db": 10.0,
        "tail_min_ms": 15,
        "tail_max_ms": 150,
        "edge_impulse_db": -3.0
      },
      "filter": {
        "enabled": true,
        "low_cut_hz": 210.0,
        "high_cut_hz": 0
      },
      "dispersion": {
        "enabled": true,
        "stages": 30,
        "center_hz": 200.0,
        "resonance": 0.1,
        "spread_octaves": 0.12,
        "spread_style": "octaves"
      },
      "compressor": {
        "enabled": true,
        "threshold_db": -40.0,
        "ratio": 10.0,
        "attack_ms": 10.0,
        "release_ms": 20.0,
        "makeup_db": 10.0
      },
      "distortion": {
        "enabled": true,
        "drive": 12.40,
        "mix": 0.40
      }
    }
  }
}
