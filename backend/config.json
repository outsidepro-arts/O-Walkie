{
  "server": {
    "port": 5500,
    "sample_rate": 8000,
    "packet_ms": 20,
    "opus": {
      "bitrate": 12000,
      "complexity": 5,
      "fec": true,
      "dtx": false,
      "application": "voip"
    },
    "hangover_ms": 180,
    "eof_timeout_ms": 420,
    "conceal_decay": 0.90,
    "jitter_min_packets": 4,
    "busy_mode": false,
    "transmit_timeout": 60
  },
  "modules": {
    "noise": {
      "enabled": true,
      "signal_dependent": true,
      "min_noise_db": -25.0,
      "max_noise_db": -3.0,
      "noise_gain": 1200.0,
      "squelch_threshold_db": -3.0,
      "squelch_min_ms": 10,
      "squelch_max_ms": 20,
      "squelch_shots_min_s": 60,
      "squelch_shots_max_s": 600,
      "tail_noise_db": 10.0,
      "tail_min_ms": 15,
      "tail_max_ms": 120,
      "noise_distribution": "gaussian",
      "thermal_lowpass_hz": 8000
    },
    "click": {
      "enabled": true,
      "pops": {
        "click_db": 0.0,
        "glitch_interval_max_ms": 600,
        "glitch_freq_min_hz": 120.0,
        "glitch_freq_max_hz": 200.0,
        "glitch_level_min_db": -25.0,
        "glitch_level_max_db": -11.0
      },
      "impulses": {
        "enabled": true,
        "prob_at_weak_signal": 0.022,
        "prob_at_strong_signal": 0.00045,
        "gain_db": -14.0
      }
    },
    "filter": {
      "enabled": true,
      "low_cut_hz": 300.0,
      "high_cut_hz": 0
    },
    "compressor": {
      "enabled": true,
      "threshold_db": -40.0,
      "ratio": 10.0,
      "attack_ms": 10.0,
      "release_ms": 20.0,
      "makeup_db": 10.0
    },
    "distortion": {
      "enabled": true,
      "drive": 10.35,
      "mix": 0.40
    }
  }
}
