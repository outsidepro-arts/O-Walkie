<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/signalNameInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/roger_name_hint"
        android:inputType="textCapWords"
        android:maxLines="1"
        android:selectAllOnFocus="true" />

    <TextView
        android:id="@+id/pointsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/roger_points_label" />

    <ListView
        android:id="@+id/pointsListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/copySignalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/signal_copy_button" />

        <Button
            android:id="@+id/pasteSignalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/signal_paste_button" />
    </LinearLayout>

    <TextView
        android:id="@+id/repeatCountLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/calling_repeat_count_label"
        android:visibility="gone" />

    <EditText
        android:id="@+id/repeatCountInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/calling_repeat_count_hint"
        android:inputType="number"
        android:maxLines="1"
        android:selectAllOnFocus="true"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/playPatternButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/play_signal_button" />

        <Button
            android:id="@+id/deletePatternButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/delete_signal_button"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/addPointButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/savePatternButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/roger_save" />

        <Button
            android:id="@+id/cancelPatternButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/roger_cancel" />
    </LinearLayout>
</LinearLayout>
