<Window x:Class="OWalkie.Desktop.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="470"
        Height="500"
        MinWidth="430"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Application settings" FontSize="18" FontWeight="Bold" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,8,0" VerticalAlignment="Center" Text="Repeater mode" />
        <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" x:Name="RepeaterCheckBox" VerticalAlignment="Center" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Text="Microphone backend" />
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" x:Name="MicrophoneComboBox" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Text="Roger preset" />
        <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" x:Name="RogerComboBox" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Text="Calling preset" />
        <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" x:Name="CallingComboBox" />

        <Border Grid.Row="5"
                Grid.ColumnSpan="2"
                Margin="0,16,0,0"
                Padding="12"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="#444">
            <StackPanel>
                <TextBlock Text="Hardware button for PTT" FontWeight="SemiBold" />
                <TextBlock x:Name="HardwareKeyStatusText" Margin="0,6,0,0" Text="Not assigned" />
                <TextBlock x:Name="HardwareKeyHintText"
                           Margin="0,6,0,0"
                           FontStyle="Italic"
                           Foreground="#777"
                           Text="Press Assign and then hit any key." />
                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                    <Button Width="120" Content="Assign" Click="AssignButton_OnClick" />
                    <Button Width="100" Margin="8,0,0,0" Content="Clear" Click="ClearButton_OnClick" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="6"
                    Grid.ColumnSpan="2"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="100" Content="Save" Click="SaveButton_OnClick" />
            <Button Width="100" Margin="8,0,0,0" Content="Cancel" Click="CancelButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
